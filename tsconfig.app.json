{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@khinemyaezin/seller-api": ["../grab-seller-shared-ui/packages/seller-api/src/index.ts"],
      "@khinemyaezin/seller-contracts": ["../grab-seller-shared-ui/packages/seller-contracts/src/index.ts"],
      "grab_seller_auth/*": ["@mf-types/grab_seller_auth/*"]
    },
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["src", "@mf-types"]
}
